# Preventia root environment template
# Copy this file to `.env` for local development.
# Never commit your real `.env`.

# Backend database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=preventia
DB_USER=preventia
DB_PASSWORD=change_me_before_prod

# JWT
JWT_SECRET=change_me_before_prod_must_be_32_bytes_or_more

# AWS / S3
AWS_REGION=ap-south-1
S3_BUCKET=preventia-prescriptions
AWS_ENDPOINT_OVERRIDE=http://localhost:4566

# External APIs
DAILY_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GEO_IP_SERVICE_URL=https://ipapi.co

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
